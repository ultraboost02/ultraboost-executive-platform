# Xano — remplir lors de la connexion API (voir src/lib/xano/)
# URL de base du workspace Xano (sans slash final), ex. https://votre-domaine.xano.io/api:xxxxx
NEXT_PUBLIC_XANO_API_URL=https://ultraboost.pro

# Clé API (côté serveur uniquement — ne pas exposer au client)
XANO_API_KEY=

# --- Xano serveur (recommandé) ---
XANO_SERVER_BASE_URL=
XANO_SERVER_API_KEY=

# --- Emails ---
ADMISSION_ADMIN_EMAIL=admin@ultraboost.pro
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ultraboost.pro

# --- Paiements ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
WAVE_API_KEY=

# --- Espace membre / JWT ---
# true = login démo (email seul, cookie ub_stub:) sans appeler Xano
MEMBRE_LOGIN_STUB=false

# POST — auth membre : body JSON { "email", "password" } → réponse avec authToken (ou token / access_token)
XANO_MEMBRE_AUTH_LOGIN_PATH=/auth/login

# GET — Bearer JWT session ; objet JSON = XanoMembreDashboard (src/lib/xano/member-types.ts)
XANO_MEMBRE_DASHBOARD_PATH=/membre/dashboard

# GET — liste commissions ; tableau OU { items: [...] } ou { data: [...] }
XANO_MEMBRE_COMMISSIONS_PATH=/membre/commissions

# GET — liste retraits
XANO_MEMBRE_RETRAITS_PATH=/membre/retraits

# POST — création retrait
XANO_MEMBRE_RETRAITS_CREATE_PATH=/retraits

# --- Admin (Xano) ---
XANO_ADMIN_AUTH_LOGIN_PATH=/admin/auth/login
XANO_ADMIN_ME_PATH=/admin/me
XANO_ADMIN_ADMISSIONS_PATH=/admin/admissions
XANO_ADMIN_RETRAITS_PATH=/admin/retraits
XANO_ADMIN_MEMBRES_PATH=/admin/membres

# --- Webhooks / Cron ---
CRON_SECRET=

# --- Mutations / tables (adapter à vos routes Xano) ---
XANO_ADMISSION_UPDATE_PATH=/admissions/{id}
XANO_USER_UPDATE_PATH=/users/{id}
XANO_USER_GET_PATH=/users/{id}
XANO_COMMISSION_CREATE_PATH=/commissions
XANO_COMMISSIONS_LIST_PENDING_PATH=/commissions?status=en_attente
XANO_COMMISSION_UPDATE_PATH=/commissions/{id}
